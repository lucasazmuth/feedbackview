generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  password  String
  createdAt DateTime  @default(now())
  projects  Project[]
}

model Project {
  id          String     @id @default(cuid())
  name        String
  description String?
  targetUrl   String
  mode        String     @default("proxy")
  ownerId     String
  owner       User       @relation(fields: [ownerId], references: [id])
  createdAt   DateTime   @default(now())
  feedbacks   Feedback[]
}

model Feedback {
  id            String         @id @default(cuid())
  projectId     String
  project       Project        @relation(fields: [projectId], references: [id])
  comment       String
  type          FeedbackType
  severity      Severity?
  status        FeedbackStatus @default(OPEN)
  screenshotUrl String?
  replayUrl     String?
  consoleLogs   Json?
  networkLogs   Json?
  metadata      Json?
  pageUrl       String?
  userAgent     String?
  createdAt     DateTime       @default(now())
}

enum FeedbackType {
  BUG
  SUGGESTION
  QUESTION
  PRAISE
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum FeedbackStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  ARCHIVED
}
