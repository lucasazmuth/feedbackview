generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  name         String?
  password     String
  createdAt    DateTime     @default(now())
  projects     Project[]
  memberships  TeamMember[]
  defaultOrgId String?
}

model Organization {
  id                   String       @id @default(cuid())
  name                 String
  slug                 String       @unique
  plan                 Plan         @default(FREE)
  planPeriod           PlanPeriod?
  planExpiresAt        DateTime?
  stripeCustomerId     String?      @unique
  stripeSubscriptionId String?      @unique
  maxProjects          Int          @default(1)
  maxMembers           Int          @default(1)
  maxReportsPerMonth   Int          @default(50)
  clickupIntegration   Json?
  createdAt            DateTime     @default(now())
  members              TeamMember[]
  projects             Project[]
  apiKeys              ApiKey[]
  webhooks             Webhook[]
}

model ApiKey {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  keyHash        String       @unique
  prefix         String
  permissions    String[]     @default(["read:feedbacks", "read:projects"])
  lastUsedAt     DateTime?
  createdAt      DateTime     @default(now())
  expiresAt      DateTime?

  @@index([organizationId])
}

model Webhook {
  id             String            @id @default(cuid())
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  url            String
  events         String[]          @default(["feedback.created"])
  secret         String
  active         Boolean           @default(true)
  createdAt      DateTime          @default(now())
  deliveries     WebhookDelivery[]

  @@index([organizationId])
}

model WebhookDelivery {
  id         String   @id @default(cuid())
  webhookId  String
  webhook    Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  event      String
  payload    Json
  statusCode Int?
  response   String?
  success    Boolean  @default(false)
  attempts   Int      @default(1)
  createdAt  DateTime @default(now())

  @@index([webhookId])
  @@index([createdAt])
}

model TeamMember {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  role           TeamRole     @default(MEMBER)
  status         MemberStatus @default(ACTIVE)
  invitedAt      DateTime     @default(now())
  joinedAt       DateTime?

  @@unique([organizationId, userId])
}

model Project {
  id             String        @id @default(cuid())
  name           String
  description    String?
  targetUrl      String
  mode           String        @default("proxy")
  ownerId        String
  owner          User          @relation(fields: [ownerId], references: [id])
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())
  feedbacks      Feedback[]
}

model Feedback {
  id             String         @id @default(cuid())
  projectId      String
  project        Project        @relation(fields: [projectId], references: [id])
  title          String?
  comment        String
  type           FeedbackType
  severity       Severity?
  status         FeedbackStatus @default(OPEN)
  screenshotUrl  String?
  replayUrl      String?
  consoleLogs    Json?
  networkLogs    Json?
  metadata       Json?
  pageUrl        String?
  userAgent      String?
  attachmentUrls Json?
  startDate      DateTime?
  dueDate        DateTime?
  clickupTaskId  String?
  sortOrder      Int            @default(0)
  createdAt      DateTime       @default(now())
  archivedAt     DateTime?

  @@index([projectId])
  @@index([projectId, status])
  @@index([projectId, createdAt])
  @@index([createdAt])
  @@index([clickupTaskId])
}

enum Plan {
  FREE
  PRO
  BUSINESS
}

enum PlanPeriod {
  MONTHLY
  YEARLY
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum MemberStatus {
  PENDING
  ACTIVE
  REMOVED
}

enum FeedbackType {
  BUG
  SUGGESTION
  QUESTION
  PRAISE
}

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum FeedbackStatus {
  OPEN
  IN_PROGRESS
  UNDER_REVIEW
  RESOLVED
  CANCELLED
  ARCHIVED
}
